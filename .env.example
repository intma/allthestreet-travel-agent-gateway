# Copy to .env for local dev. Do NOT commit real secrets.
# On Cloud Run, set these via --set-env-vars or Secret Manager.

SOURCE_API_BASE=https://api.allthestreet.com
PUBLIC_BASE_URL=http://localhost:8080
CORS_ORIGINS=https://korea.allthestreet.com,http://localhost:8080
GATEWAY_API_KEY=
# Server-side only — used to proxy Google Place photos. Keep secret.
GOOGLE_MAPS_API_KEY=
PLACE_PHOTO_MAX_WIDTH=800
# MCP host allowlist. "*" disables host check (public read-only MCP). On Cloud Run can set to the run.app host.
MCP_ALLOWED_HOSTS=*
ENV=development
